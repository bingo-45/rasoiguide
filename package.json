{
  "name": "rasoiguide",
  "version": "2.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @rasoiguide/web dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "intent:eval": "tsx packages/voice/src/eval/run.ts",
    "fixtures:audio": "node scripts/generate-audio-fixtures.mjs",
    "photos:sync": "node scripts/download-licensed-photos.mjs",
    "e2e": "playwright test",
    "lighthouse": "node scripts/run-lighthouse.mjs",
    "lighthouse:ci": "lhci autorun",
    "lint": "eslint . --max-warnings=0",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm intent:eval && pnpm build"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "lighthouse": "^12.6.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
